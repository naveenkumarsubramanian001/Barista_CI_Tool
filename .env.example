# Barista CI Tool — Environment Variables
# Copy to .env and fill in your API keys

# --- LLM Provider (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Search Providers (at least one required) ---
# Tavily (recommended — best quality for research)
TAVILY_API_KEY=

# Serper (Google Search API alternative)
SERPER_API_KEY=

# Bing Search
BING_SEARCH_API_KEY=

# Google Custom Search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- Search Configuration ---
# Options: tavily, serper, bing, google
# Falls back automatically if the chosen provider has no key
SEARCH_PROVIDER=tavily
